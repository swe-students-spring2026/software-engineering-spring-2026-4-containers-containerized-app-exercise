# Copy this file to .env and fill in the real values for your environment.
# Do not commit .env to Git.

# Roboflow model endpoint and key
ML_MODEL_URL=https://serverless.roboflow.com
ML_MODEL_API_KEY=your_api_key_here
ML_MODEL_ID=garbage-classification-3/2

# MongoDB connection
MONGO_URI=mongodb://localhost:27017/
DB_NAME=garbage_classifier
